{
  "extends": ["schedule:monthly", ":dependencyDashboard", "config:recommended"],
  "prHourlyLimit": 0,
  "lockFileMaintenance": {
    "extends": ["schedule:weekly"],
    "automerge": true,
    "enabled": true
  },
  "automerge": true,
  "postUpdateOptions": ["pnpmDedupe"],
  "separateMajorMinor": false,
  "updateNotScheduled": false,
  "rangeStrategy": "bump",
  "labels": ["ci:auto-merge", "dependencies"],
  "prConcurrentLimit": 3
}
