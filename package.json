{
  "name": "mcpmarket-better",
  "description": "Userscript that enhances mcpmarket.com search",
  "version": "0.2.3",
  "author": {
    "name": "Brighten Tompkins",
    "email": "brightenqtompkins@gmail.com"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "format": "prettier -w ./",
    "analize": "cross-env npm_config_report=true pnpm run build",
    "build": "webpack --config config/webpack.config.prod.cjs && cp dist/index.prod.user.js mcpmarket-better.user.js",
    "dev": "webpack --config config/webpack.config.dev.cjs",
    "prepare": "husky install",
    "lint-staged": "lint-staged"
  },
  "private": true,
  "dependencies": {
    "@trim21/gm-fetch": "^0.3.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier --ignore-path ./.prettierignore --write "
    ]
  },
  "devDependencies": {
    "@types/greasemonkey": "^4.0.7",
    "@types/node": "^22.17.0",
    "browserslist": "^4.28.4",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "husky": "^9.1.7",
    "less": "^4.6.7",
    "less-loader": "^13.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.2",
    "typescript": "^5.9.3",
    "userscript-metadata-webpack-plugin": "^0.4.2",
    "webpack": "^5.108.3",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.1.0",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-merge": "^6.0.1",
    "webpack-sources": "^3.5.0"
  }
}
